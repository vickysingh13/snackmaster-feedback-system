generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Machine {
  id          Int          @id @default(autoincrement())
  machineCode String       @unique @map("machine_code") @db.VarChar(20)
  name        String?      @db.VarChar(255)
  location    String       @db.VarChar(255)
  area        String?      @db.VarChar(100)
  qrCodeUrl   String?      @map("qr_code_url") @db.VarChar(255)
  status      String?      @default("active") @db.VarChar(20)
  deletedAt   DateTime?    @map("deleted_at") @db.Timestamp(6)
  createdAt   DateTime?    @default(now()) @map("created_at") @db.Timestamp(6)
  submissions Submission[]
  uiConfig    MachineUiConfig?

  @@map("machines")
}

model MachineUiConfig {
  id              Int       @id @default(autoincrement())
  machineId       Int       @unique @map("machine_id")
  bannerMessage   String?   @map("banner_message") @db.Text
  highlightText   String?   @map("highlight_text") @db.Text
  imageUrl        String?   @map("image_url") @db.VarChar(500)
  pollQuestion    String?   @map("poll_question") @db.Text
  pollOptions     Json?     @default("[]") @map("poll_options")
  pollActive      Boolean?  @default(false) @map("poll_active")
  showWhatsapp    Boolean?  @default(true) @map("show_whatsapp")
  createdAt       DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt       DateTime? @default(now()) @map("updated_at") @db.Timestamp(6)
  machine         Machine   @relation(fields: [machineId], references: [id], onDelete: Cascade)

  @@map("machine_ui_configs")
}

model Submission {
  id             Int       @id @default(autoincrement())
  machineId      Int?      @map("machine_id")
  type           String    @db.VarChar(50)
  data           Json      @default("{}")
  status         String?   @default("pending") @db.VarChar(30)
  whatsappStatus String?   @default("not_contacted") @map("whatsapp_status") @db.VarChar(30)
  adminNotes     String?   @map("admin_notes")
  refundStatus   String?   @default("pending") @map("refund_status") @db.VarChar(30)
  adminRemarks   String?   @map("admin_remarks")
  notes          String?
  createdAt      DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt      DateTime? @default(now()) @map("updated_at") @db.Timestamp(6)
  machine        Machine?  @relation(fields: [machineId], references: [id], onUpdate: NoAction)

  @@index([machineId], map: "idx_submissions_machine_id")
  @@index([type], map: "idx_submissions_type")
  @@index([status], map: "idx_submissions_status")
  @@index([createdAt(sort: Desc)], map: "idx_submissions_created_at")
  @@map("submissions")
}

model FormConfig {
  id           Int       @id @default(autoincrement())
  type         String    @unique @db.VarChar(50)
  label        String    @db.VarChar(100)
  isEnabled    Boolean?  @default(true) @map("is_enabled")
  fields       Json      @default("[]")
  displayOrder Int?      @default(0) @map("display_order")
  updatedAt    DateTime? @default(now()) @map("updated_at") @db.Timestamp(6)

  @@map("form_configs")
}

model AdminUser {
  id           Int       @id @default(autoincrement())
  email        String    @unique @db.VarChar(255)
  passwordHash String    @map("password_hash") @db.VarChar(255)
  name         String?   @default("Admin") @db.VarChar(100)
  createdAt    DateTime? @default(now()) @map("created_at") @db.Timestamp(6)

  @@map("admin_users")
}

model WeeklyConfig {
  id        Int       @id @default(autoincrement())
  title     String    @db.VarChar(255)
  startDate DateTime? @map("start_date") @db.Date
  endDate   DateTime? @map("end_date") @db.Date
  isActive  Boolean?  @default(true) @map("is_active")
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt DateTime? @default(now()) @map("updated_at") @db.Timestamp(6)

  @@map("weekly_config")
}

model PollResponse {
  id        Int       @id @default(autoincrement())
  machineId Int       @map("machine_id")
  option    String    @db.VarChar(255)
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamp(6)

  @@index([machineId], map: "idx_poll_responses_machine_id")
  @@map("poll_responses")
}
